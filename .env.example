# Copy to .env and fill in. Values shown are the in-code defaults (app/config.py).
# Blank entries below are REQUIRED — the app will not start without them.

# --- Core services (required) ---
DATABASE_URL=postgresql://rag:rag@localhost:5432/movierag
TMDB_API_KEY=                       # ingestion only (scripts/run_ingest.py)
CEREBRAS_API_KEY=                   # answer generation (POST /query)
CEREBRAS_MODEL=gpt-oss-120b

# --- Auth (JWT_SECRET_KEY is required) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be >=32 chars and not a known-weak value, or startup aborts.
JWT_SECRET_KEY=
JWT_SECRET_KEY_PREVIOUS=            # set only during secret rotation, then clear
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=movie-rag
JWT_AUDIENCE=movie-rag-api
LOGIN_RATE_LIMIT=5/minute

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
OAUTH_SESSION_SECRET=

# --- Refresh cookie / CORS ---
# Dev defaults assume the Vite proxy on localhost:5173.
# Split-origin prod: SECURE=true, SAMESITE=none, CORS_ORIGINS=https://app.example.com
REFRESH_COOKIE_NAME=mr_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173

# --- Eval only ---
GROQ_API_KEY=                       # Ragas judge (python -m eval.run)
